@model BTT6.Models.Category

<h2>Xóa chủ đề</h2>

<div class="alert alert-danger">
    <h4>Bạn có chắc chắn muốn xóa chủ đề này?</h4>
    <p>Tất cả sản phẩm thuộc chủ đề "<strong>@Model.CategoryName</strong>" cũng sẽ bị xóa.</p>
    @if (Model.Products != null && Model.Products.Any())
    {
        <p>Số sản phẩm sẽ bị xóa: <strong>@Model.Products.Count</strong></p>
    }
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Tên chủ đề</dt>
            <dd class="col-sm-9">@Model.CategoryName</dd>
            <dt class="col-sm-3">Mô tả</dt>
            <dd class="col-sm-9">@Model.Description</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="CategoryId" />
    <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>
