@model IEnumerable<BTT6.Models.Product>

<h2 class="page-title"><i class="fas fa-boxes-stacked me-2"></i>Quản lý Sản phẩm</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Thêm sản phẩm mới
    </a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tên sản phẩm</th>
            <th>Giá</th>
            <th>Chủ đề</th>
            <th style="width: 200px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductId</td>
                <td><strong>@item.ProductName</strong></td>
                <td class="price-tag">@item.Price.ToString("N0") VNĐ</td>
                <td><span class="category-badge">@item.Category?.CategoryName</span></td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">
                        <i class="fas fa-edit"></i> Sửa
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-danger">
                        <i class="fas fa-trash"></i> Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
