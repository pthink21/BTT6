@model BTT6.Models.Product

<h2>Xóa sản phẩm</h2>

<div class="alert alert-danger">
    <h4>Bạn có chắc chắn muốn xóa sản phẩm này?</h4>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Tên sản phẩm</dt>
            <dd class="col-sm-9">@Model.ProductName</dd>
            <dt class="col-sm-3">Mô tả</dt>
            <dd class="col-sm-9">@Model.Description</dd>
            <dt class="col-sm-3">Giá</dt>
            <dd class="col-sm-9">@Model.Price.ToString("N0") VNĐ</dd>
            <dt class="col-sm-3">Chủ đề</dt>
            <dd class="col-sm-9">@Model.Category?.CategoryName</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="ProductId" />
    <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>
