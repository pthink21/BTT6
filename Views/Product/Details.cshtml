@model BTT6.Models.Product

<h2 class="page-title">Chi tiết sản phẩm</h2>

<div class="card product-detail-card">
    <div class="card-body">
        <span class="category-badge mb-3 d-inline-block">@Model.Category?.CategoryName</span>
        <h3 class="mt-2">@Model.ProductName</h3>
        <hr />
        <div class="row mt-4">
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-4 text-muted">Mô tả</dt>
                    <dd class="col-sm-8">@Model.Description</dd>
                    <dt class="col-sm-4 text-muted">Chủ đề</dt>
                    <dd class="col-sm-8">@Model.Category?.CategoryName</dd>
                </dl>
            </div>
            <div class="col-md-4 text-center">
                <div class="bg-light p-4 rounded-4">
                    <p class="text-muted mb-1">Giá bán</p>
                    <h3 class="price-tag">@Model.Price.ToString("N0") VNĐ</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>
